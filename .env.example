# Server
PORT=3000

# AI Service API Keys
OPENROUTER_API_KEY=
# VISION_MODEL=google/gemini-2.5-flash-lite
# CLASSIFICATION_MODEL=google/gemini-2.5-flash-lite
AWS_REGION=us-east-1
AWS_REKOGNITION_COLLECTION_ID=suhail-faces
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# App Configuration
DEFAULT_LANGUAGE=ar
CONFIDENCE_THRESHOLD=0.5

# Mobile Relay (BLE app)
# Shared secret for HMAC-Bearer auth between the BLE mobile app and the relay
# endpoints (/api/intent, /api/normalize, /api/vision/*, /api/faces/*, /api/tts, /api/stt).
# The mobile app holds this same value (baked into the build via EXPO_PUBLIC_*).
# Soft secret — bundled in the mobile binary — rotate by re-releasing.
# When EMPTY, relay endpoints are open (dev mode, with a warning at startup).
# Generate one with: openssl rand -hex 32
RELAY_SHARED_SECRET=

# ElevenLabs (server-side TTS for /api/tts + Scribe STT for /api/stt).
# Held ONLY on the server — never shipped to the mobile binary.
# When empty, /api/tts and /api/stt return 503.
#
# IMPORTANT — paid plan required for our default voices.
# The default voice presets (default/male/female) are stock library voices
# (Rachel, Adam). ElevenLabs Free tier returns HTTP 402 for library voices via
# API: "Free users cannot use library voices via the API." Minimum working
# plan as of 2026: Starter ($6/mo). Alternatively, clone a custom voice on
# Free (10 min/month cap) and set ELEVENLABS_DEFAULT_VOICE_ID to its ID.
ELEVENLABS_API_KEY=
# Stock voice IDs come from https://elevenlabs.io/app/voice-library
# Default is "Rachel" (21m00Tcm4TlvDq8ikWAM), a multilingual female voice.
# ELEVENLABS_DEFAULT_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# Model — flash v2.5 is multilingual + ~75ms latency. Other options:
# eleven_v3, eleven_turbo_v2_5, eleven_multilingual_v2
# ELEVENLABS_MODEL=eleven_flash_v2_5
