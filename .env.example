# MentraOS Configuration
PACKAGE_NAME=com.suhail.assistant
MENTRAOS_API_KEY=
PORT=3000

# AI Service API Keys
OPENROUTER_API_KEY=
# VISION_MODEL=google/gemini-2.5-flash-lite
# CLASSIFICATION_MODEL=google/gemini-2.5-flash-lite
AWS_REGION=us-east-1
AWS_REKOGNITION_COLLECTION_ID=suhail-faces
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# App Configuration
DEFAULT_LANGUAGE=ar
CONFIDENCE_THRESHOLD=0.5
MIN_CONFIDENCE=0.55

# Publicly reachable base URL of this server (no trailing slash).
# Dev: your ngrok URL. Prod: your Railway URL.
# When set, short generated chimes replace the "Listening" / "Got it" / "Cancelled"
# TTS cues (saves ~4-5s per command). Leave empty to keep the spoken fallback.
# PUBLIC_BASE_URL=https://unplummeted-teddy-extractable.ngrok-free.dev

# Mobile Relay (BLE app)
# Shared secret for HMAC-Bearer auth between the BLE mobile app and the relay
# endpoints under /api/intent, /api/vision/*, /api/faces/* (POST), /api/tts.
# The mobile app holds this same value (baked into the build via EXPO_PUBLIC_*).
# Soft secret — bundled in the mobile binary — rotate by re-releasing.
# When EMPTY, relay endpoints are open (dev mode, with a warning at startup).
# Generate one with: openssl rand -hex 32
RELAY_SHARED_SECRET=
