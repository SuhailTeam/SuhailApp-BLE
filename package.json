{
  "name": "suhail",
  "version": "1.0.0",
  "description": "Suhail — AI Smart Glasses for the Visually Impaired (MentraOS App)",
  "main": "src/index.ts",
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun run --watch src/index.ts",
    "build": "cd landing && bun install && bun run build",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "test": "bun test",
    "test:mobile": "cd mobile && bun test",
    "test:all": "bun test && cd mobile && bun test",
    "gp2:results": "bun run testing/run_all.ts"
  },
  "dependencies": {
    "@aws-sdk/client-rekognition": "^3.887.0",
    "@mentra/sdk": "2.1.29",
    "@types/multer": "^2.1.0",
    "multer": "^2.1.1",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/sharp": "^0.32.0",
    "typescript": "^5.3.0"
  }
}
