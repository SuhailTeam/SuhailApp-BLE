# Mobile env vars are baked into the build at compile time.
# Anything prefixed with EXPO_PUBLIC_ is exposed at runtime via process.env.
# Do NOT put real secrets here — the binary ships these to every user.

# Railway relay base URL (no trailing slash).
# Dev: ngrok URL of your local server. Prod: Railway URL.
EXPO_PUBLIC_RELAY_BASE_URL=

# HMAC shared secret matching RELAY_SHARED_SECRET on the server.
# Soft secret — bundled in the app binary. Rotate by re-releasing.
# Leave blank for local dev where the server also has it blank.
EXPO_PUBLIC_RELAY_SHARED_SECRET=

# Optional log verbosity: debug | info | warn | error
EXPO_PUBLIC_LOG_LEVEL=info

# Optional: pin a specific deviceId for development (otherwise auto-generated and stored in MMKV).
# EXPO_PUBLIC_DEV_DEVICE_ID=dev-android-1
